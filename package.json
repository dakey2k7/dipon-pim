{
  "name": "dipon-pim",
  "version": "1.0.0",
  "description": "DIPON PIM \u2013 Lokale Desktop & Web App",
  "main": "./out/main/index.js",
  "author": "DIPON.DE GmbH & Co. KG",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package:win": "npm run build && electron-builder --win --x64",
    "web": "concurrently -n SERVER,CLIENT -c cyan,magenta \"npm run web:server\" \"npm run web:client\"",
    "web:server": "ts-node-dev --respawn --transpile-only --project server/tsconfig.json server/src/index.ts",
    "web:client": "vite --config vite.web.config.ts",
    "web:build": "tsc -p server/tsconfig.json && vite build --config vite.web.config.ts"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "electron-updater": "^6.1.8",
    "express": "^4.18.3",
    "flag-icons": "^7.5.0",
    "react-grid-layout": "^2.2.3"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.28.4",
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.67",
    "@types/react-dom": "^18.2.22",
    "@types/react-grid-layout": "^1.3.6",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "electron": "29.1.5",
    "electron-builder": "24.13.3",
    "electron-vite": "2.3.0",
    "lucide-react": "^0.363.0",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "tailwindcss": "^3.4.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2",
    "vite": "5.4.21",
    "zustand": "^4.5.2"
  },
  "build": {
    "appId": "de.dipon.pim",
    "productName": "DIPON PIM",
    "copyright": "\u00a9 DIPON.DE GmbH & Co. KG",
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "files": [
      "out/**/*",
      "!out/**/*.map"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "DIPON PIM"
    }
  }
}