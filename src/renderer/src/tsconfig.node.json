{
  "compilerOptions": {
    "composite":              true,
    "module":                 "ESNext",
    "moduleResolution":       "bundler",
    "target":                 "ES2022",
    "lib":                    ["ES2022"],
    "skipLibCheck":           true,
    "strict":                 true,
    "esModuleInterop":        true,
    "resolveJsonModule":      true,
    "outDir":                 "out",
    "paths": {
      "@main/*": ["src/main/*"]
    }
  },
  "include": ["src/main/**/*", "src/preload/**/*", "electron.vite.config.ts"]
}
