{
  "compilerOptions": {
    "composite":                    true,
    "target":                       "ES2020",
    "useDefineForClassFields":      true,
    "lib":                          ["ES2020", "DOM", "DOM.Iterable"],
    "module":                       "ESNext",
    "moduleResolution":             "bundler",
    "skipLibCheck":                 true,
    "strict":                       true,
    "jsx":                          "react-jsx",
    "noEmit":                       true,
    "allowImportingTsExtensions":   true,
    "resolveJsonModule":            true,
    "baseUrl":                      ".",
    "paths": {
      "@/*": ["src/renderer/src/*"]
    }
  },
  "include": ["src/renderer/src/**/*", "src/preload/index.d.ts"]
}
